# Local development (Docker Postgres) — see docker-compose.yml
# Production: replace with Neon connection strings
#   DATABASE_URL  -> Neon pooled connection (pgbouncer)
#   DIRECT_URL    -> Neon direct connection (used by Prisma Migrate)
DATABASE_URL="postgresql://eventpro:eventpro@localhost:5432/eventpro?schema=public"
DIRECT_URL="postgresql://eventpro:eventpro@localhost:5432/eventpro?schema=public"
